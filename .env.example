# Birdeye API Key (get from https://birdeye.so/developers)
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Monitor interval in seconds (default: 300 = 5 min)
MONITOR_INTERVAL=300

# K-line type: "1H" for hourly, "1D" for daily
KLINE_TYPE=1H

# Number of consecutive candles to check (default: 3)
CANDLE_COUNT=3

# Max amplitude percentage for buy signal (default: 10)
MAX_AMPLITUDE_PCT=10

# Solana RPC URL (optional, for future trading)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
