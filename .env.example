# Solana RPC endpoint
RPC_URL=

# Base58-encoded private key of your trading wallet
WALLET_PRIVATE_KEY=

# Birdeye API key for market data (https://birdeye.so)
BIRDEYE_API_KEY=

# Dashboard web UI port (default: 3000)
DASHBOARD_PORT=3000

# Monitoring interval in seconds (default: 300 = 5 min)
MONITOR_INTERVAL_SEC=300

# Maximum USDT to spend per single buy trade
MAX_BUY_USDT=50

# Slippage tolerance in bps (100 = 1%, 300 = 3%)
SLIPPAGE_BPS=100

# Set to true to simulate trades without actually sending transactions
DRY_RUN=true

# ── Risk Management ────────────────────────────────────────────────────────
STOP_LOSS_PCT=20
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS_USDT=100
MAX_HOLD_HOURS=72
MAX_PRICE_IMPACT_PCT=3
MIN_USDT_RESERVE=20
